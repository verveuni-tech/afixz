rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyKeys(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    function hasRequiredKeys(data, requiredKeys) {
      return data.keys().hasAll(requiredKeys);
    }

    function hasField(data, field) {
      return data.keys().hasAny([field]);
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function optionalString(data, field) {
      return !hasField(data, field) || data[field] is string;
    }

    function optionalTimestampOrNull(data, field) {
      return !hasField(data, field) || data[field] == null || data[field] is timestamp;
    }

    function optionalMapOrString(data, field) {
      return !hasField(data, field) || data[field] is map || data[field] is string;
    }

    function validService(data) {
      return hasOnlyKeys(data, [
          "title", "slug", "price", "duration", "warranty",
          "professionals", "overview", "included", "images",
          "categoryId", "categorySlug", "searchKeywords", "rating",
          "reviewCount", "isRecommended", "createdAt", "updatedAt"
        ])
        && hasRequiredKeys(data, [
          "title", "slug", "price", "duration", "warranty",
          "professionals", "overview", "included", "images",
          "categoryId", "categorySlug", "searchKeywords", "rating",
          "reviewCount", "isRecommended", "createdAt", "updatedAt"
        ])
        && data.title is string
        && data.slug is string
        && isNumber(data.price)
        && data.duration is string
        && data.warranty is string
        && (data.professionals is string || isNumber(data.professionals))
        && data.overview is string
        && data.included is list
        && data.images is list
        && data.categoryId is string
        && data.categorySlug is string
        && data.searchKeywords is list
        && isNumber(data.rating)
        && isNumber(data.reviewCount)
        && data.isRecommended is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validCategory(data) {
      return hasOnlyKeys(data, ["name", "slug", "createdAt"])
        && hasRequiredKeys(data, ["name", "slug", "createdAt"])
        && data.name is string
        && data.slug is string
        && data.createdAt is timestamp;
    }

    function validBlog(data) {
      return hasOnlyKeys(data, [
          "title", "slug", "excerpt", "content", "author",
          "category", "tags", "status", "published", "publishedAt",
          "coverImage", "coverImagePublicId", "ogImage", "seoTitle",
          "seoDescription", "canonicalUrl", "readTime", "searchKeywords",
          "createdAt", "updatedAt"
        ])
        && hasRequiredKeys(data, [
          "title", "slug", "excerpt", "content", "author",
          "category", "tags", "status", "published",
          "coverImage", "coverImagePublicId", "ogImage", "seoTitle",
          "seoDescription", "canonicalUrl", "readTime", "searchKeywords",
          "updatedAt"
        ])
        && data.title is string
        && data.slug is string
        && data.excerpt is string
        && data.content is string
        && data.author is string
        && data.category is string
        && data.tags is list
        && data.status is string
        && data.published is bool
        && optionalTimestampOrNull(data, "publishedAt")
        && data.coverImage is string
        && data.coverImagePublicId is string
        && data.ogImage is string
        && data.seoTitle is string
        && data.seoDescription is string
        && data.canonicalUrl is string
        && data.readTime is string
        && data.searchKeywords is list
        && optionalTimestampOrNull(data, "createdAt")
        && data.updatedAt is timestamp;
    }

    function validUserProfile(data) {
      return hasOnlyKeys(data, [
          "uid", "phone", "email", "provider", "role",
          "createdAt", "updatedAt"
        ])
        && hasRequiredKeys(data, [
          "uid", "role", "createdAt", "updatedAt"
        ])
        && data.uid is string
        && (data.phone == null || data.phone is string)
        && (data.email == null || data.email is string)
        && (data.provider == null || data.provider is string)
        && data.role is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validCartItem(data, cartItemId) {
      return hasOnlyKeys(data, ["serviceId", "title", "price", "slug", "addedAt"])
        && hasRequiredKeys(data, ["serviceId", "title", "price", "slug", "addedAt"])
        && data.serviceId is string
        && data.serviceId == cartItemId
        && data.title is string
        && isNumber(data.price)
        && data.slug is string
        && data.addedAt is timestamp;
    }

    function validAddress(data) {
      return hasOnlyKeys(data, [
          "fullName", "phone", "line1", "city",
          "state", "pincode", "createdAt"
        ])
        && hasRequiredKeys(data, [
          "fullName", "phone", "line1", "city",
          "state", "pincode", "createdAt"
        ])
        && data.fullName is string
        && data.phone is string
        && data.line1 is string
        && data.city is string
        && data.state is string
        && data.pincode is string
        && data.createdAt is timestamp;
    }

    function validBooking(data) {
      return hasOnlyKeys(data, [
          "userId", "services", "totalPrice", "address",
          "scheduledDate", "scheduledTime", "paymentMode", "status",
          "createdAt", "serviceId", "serviceSlug", "serviceTitle",
          "price", "customerName", "customerPhone"
        ])
        && hasRequiredKeys(data, [
          "userId", "scheduledDate", "scheduledTime",
          "paymentMode", "status", "createdAt"
        ])
        && data.userId is string
        && data.userId == request.auth.uid
        && data.scheduledDate is string
        && data.scheduledTime is string
        && data.paymentMode == "cod"
        && data.status == "pending"
        && data.createdAt is timestamp
        && optionalMapOrString(data, "address")
        && (!hasField(data, "services") || data.services is list)
        && (!hasField(data, "totalPrice") || isNumber(data.totalPrice))
        && optionalString(data, "serviceId")
        && optionalString(data, "serviceSlug")
        && optionalString(data, "serviceTitle")
        && (!hasField(data, "price") || isNumber(data.price))
        && optionalString(data, "customerName")
        && optionalString(data, "customerPhone")
        && (hasField(data, "services") || hasField(data, "serviceId"));
    }

    /* ---------------- SERVICES ---------------- */

    match /services/{doc} {
      allow read: if true;
      allow create, update: if isAdmin() && validService(request.resource.data);
      allow delete: if isAdmin();
    }

    /* ---------------- CATEGORIES ---------------- */

    match /categories/{doc} {
      allow read: if true;
      allow create, update: if isAdmin() && validCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    /* ---------------- BLOGS ---------------- */

    match /blogs/{doc} {
      allow read: if true;
      allow create, update: if isAdmin() && validBlog(request.resource.data);
      allow delete: if isAdmin();
    }

    /* ---------------- USERS ---------------- */

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (
          isOwner(userId)
          && request.resource.data.uid == userId
          && request.resource.data.role == "user"
          && validUserProfile(request.resource.data)
        ) || (
          isAdmin()
          && request.resource.data.uid == userId
          && validUserProfile(request.resource.data)
        );
      allow update: if (
          isOwner(userId)
          && request.resource.data.uid == userId
          && request.resource.data.role == resource.data.role
          && resource.data.role == "user"
          && validUserProfile(request.resource.data)
        ) || (
          isAdmin()
          && request.resource.data.uid == userId
          && validUserProfile(request.resource.data)
        );
      allow delete: if isAdmin();
    }

    match /users/{userId}/cart/{cartItemId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && validCartItem(request.resource.data, cartItemId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/addresses/{addressId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) || isAdmin()) && validAddress(request.resource.data);
      allow delete: if isOwner(userId) || isAdmin();
    }

    /* ---------------- BOOKINGS ---------------- */

    match /bookings/{bookingId} {
      allow create: if isSignedIn() && validBooking(request.resource.data);

      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.userId
          || isAdmin()
        );

      allow update, delete: if isAdmin();
    }
  }
}
