rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyKeys(data, allowedKeys) {
      return data.keys().hasOnly(allowedKeys);
    }

    function hasRequiredKeys(data, requiredKeys) {
      return data.keys().hasAll(requiredKeys);
    }

    function hasField(data, field) {
      return data.keys().hasAny([field]);
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function isValidLocation(locationId) {
      return locationId == "delhi"
        || locationId == "noida"
        || locationId == "gurgaon";
    }

    function optionalString(data, field) {
      return !hasField(data, field) || data[field] is string;
    }

    function optionalNullableString(data, field) {
      return !hasField(data, field) || data[field] == null || data[field] is string;
    }

    function optionalTimestampOrNull(data, field) {
      return !hasField(data, field) || data[field] == null || data[field] is timestamp;
    }

    function optionalMapOrString(data, field) {
      return !hasField(data, field) || data[field] is map || data[field] is string;
    }

    function serviceDoc(serviceId) {
      return get(/databases/$(database)/documents/services/$(serviceId));
    }

    function serviceExists(serviceId) {
      return exists(/databases/$(database)/documents/services/$(serviceId));
    }

    function serviceSupportsLocation(serviceId, locationId) {
      return !serviceDoc(serviceId).data.keys().hasAny(["availableLocations"])
        || serviceDoc(serviceId).data.availableLocations.hasAny([locationId]);
    }

    function servicePriceMatches(serviceId, locationId, price) {
      return (
        serviceDoc(serviceId).data.keys().hasAny(["priceByLocation"])
        && serviceDoc(serviceId).data.priceByLocation.keys().hasAny([locationId])
        && price == serviceDoc(serviceId).data.priceByLocation[locationId]
      ) || price == serviceDoc(serviceId).data.price;
    }

    function validService(data) {
      return hasOnlyKeys(data, [
          "title", "slug", "price", "duration", "warranty",
          "professionals", "overview", "included", "images",
          "categoryId", "categorySlug", "searchKeywords", "rating",
          "reviewCount", "isRecommended", "availableLocations",
          "contentByLocation", "priceByLocation", "createdAt", "updatedAt"
        ])
        && hasRequiredKeys(data, [
          "title", "slug", "price", "duration", "warranty",
          "professionals", "overview", "included", "images",
          "categoryId", "categorySlug", "searchKeywords", "rating",
          "reviewCount", "isRecommended", "availableLocations", "updatedAt"
        ])
        && data.title is string
        && data.slug is string
        && isNumber(data.price)
        && data.duration is string
        && data.warranty is string
        && (data.professionals is string || isNumber(data.professionals))
        && data.overview is string
        && data.included is list
        && data.images is list
        && data.categoryId is string
        && data.categorySlug is string
        && data.searchKeywords is list
        && isNumber(data.rating)
        && isNumber(data.reviewCount)
        && data.isRecommended is bool
        && data.availableLocations is list
        && data.contentByLocation is map
        && data.priceByLocation is map
        && optionalTimestampOrNull(data, "createdAt")
        && data.updatedAt is timestamp;
    }

    function validCategory(data) {
      return hasOnlyKeys(data, ["name", "slug", "createdAt"])
        && hasRequiredKeys(data, ["name", "slug", "createdAt"])
        && data.name is string
        && data.slug is string
        && data.createdAt is timestamp;
    }

    function validBlog(data) {
      return hasOnlyKeys(data, [
          "title", "slug", "excerpt", "content", "author",
          "category", "tags", "status", "published", "publishedAt",
          "coverImage", "coverImagePublicId", "ogImage", "seoTitle",
          "seoDescription", "canonicalUrl", "readTime", "searchKeywords",
          "availableLocations", "contentByLocation", "createdAt", "updatedAt"
        ])
        && hasRequiredKeys(data, [
          "title", "slug", "excerpt", "content", "author",
          "category", "tags", "status", "published",
          "coverImage", "coverImagePublicId", "ogImage", "seoTitle",
          "seoDescription", "canonicalUrl", "readTime", "searchKeywords",
          "updatedAt"
        ])
        && data.title is string
        && data.slug is string
        && data.excerpt is string
        && data.content is string
        && data.author is string
        && data.category is string
        && data.tags is list
        && data.status is string
        && data.published is bool
        && optionalTimestampOrNull(data, "publishedAt")
        && data.coverImage is string
        && data.coverImagePublicId is string
        && data.ogImage is string
        && data.seoTitle is string
        && data.seoDescription is string
        && data.canonicalUrl is string
        && data.readTime is string
        && data.searchKeywords is list
        && (!hasField(data, "availableLocations") || data.availableLocations is list)
        && (!hasField(data, "contentByLocation") || data.contentByLocation is map)
        && optionalTimestampOrNull(data, "createdAt")
        && data.updatedAt is timestamp;
    }

    function validHomepageContent(data) {
      return hasOnlyKeys(data, ["default", "byLocation", "updatedAt"])
        && hasRequiredKeys(data, ["default", "updatedAt"])
        && data.default is map
        && (!hasField(data, "byLocation") || data.byLocation is map)
        && data.updatedAt is timestamp;
    }

    // UPDATED
    function validUserProfile(data, userId) {
      return hasOnlyKeys(data, [
          "uid", "displayName", "photoURL", "phone", "email",
          "provider", "role", "selectedLocation", "createdAt", "updatedAt"
        ])
        && hasRequiredKeys(data, [
          "uid", "provider", "role", "createdAt", "updatedAt"
        ])
        && data.uid is string
        && data.uid == userId
        && optionalNullableString(data, "displayName")
        && optionalNullableString(data, "photoURL")
        && optionalNullableString(data, "phone")
        && optionalNullableString(data, "email")
        && data.provider is string
        && (data.provider == "phone" || data.provider == "google.com")
        && data.role is string
        && (data.role == "user" || data.role == "admin")
        && (
          (data.role == "user" && data.provider == "phone")
          || (data.role == "admin" && data.provider == "google.com")
        )
        && (!hasField(data, "selectedLocation")
          || data.selectedLocation == null
          || isValidLocation(data.selectedLocation))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function validCartItem(data, cartItemId) {
      return hasOnlyKeys(data, ["serviceId", "title", "price", "slug", "locationId", "addedAt"])
        && hasRequiredKeys(data, ["serviceId", "title", "price", "slug", "locationId", "addedAt"])
        && data.serviceId is string
        && data.serviceId == cartItemId
        && serviceExists(data.serviceId)
        && data.title is string
        && isNumber(data.price)
        && data.slug is string
        && data.locationId is string
        && isValidLocation(data.locationId)
        && serviceSupportsLocation(data.serviceId, data.locationId)
        && servicePriceMatches(data.serviceId, data.locationId, data.price)
        && data.addedAt is timestamp;
    }

    function validAddress(data) {
      return hasOnlyKeys(data, [
          "fullName", "phone", "line1", "city",
          "state", "pincode", "createdAt"
        ])
        && hasRequiredKeys(data, [
          "fullName", "phone", "line1", "city",
          "state", "pincode", "createdAt"
        ])
        && data.fullName is string
        && data.phone is string
        && data.line1 is string
        && data.city is string
        && data.state is string
        && data.pincode is string
        && data.createdAt is timestamp;
    }

    function validBooking(data) {
      return hasOnlyKeys(data, [
          "orderGroupId", "userId", "serviceId", "serviceSlug", "serviceTitle",
          "price", "totalPrice", "locationId", "address", "scheduledDate",
          "scheduledTime", "paymentMode", "status", "createdAt",
          "customerName", "customerPhone"
        ])
        && hasRequiredKeys(data, [
          "userId", "serviceId", "serviceSlug", "serviceTitle",
          "price", "totalPrice", "locationId", "scheduledDate",
          "scheduledTime", "paymentMode", "status", "createdAt"
        ])
        && data.userId is string
        && data.userId == request.auth.uid
        && data.serviceId is string
        && serviceExists(data.serviceId)
        && data.serviceSlug is string
        && data.serviceTitle is string
        && isNumber(data.price)
        && isNumber(data.totalPrice)
        && data.totalPrice == data.price
        && data.locationId is string
        && isValidLocation(data.locationId)
        && serviceSupportsLocation(data.serviceId, data.locationId)
        && servicePriceMatches(data.serviceId, data.locationId, data.price)
        && data.scheduledDate is string
        && data.scheduledTime is string
        && data.paymentMode == "cod"
        && data.status == "pending"
        && optionalString(data, "orderGroupId")
        && optionalMapOrString(data, "address")
        && optionalString(data, "customerName")
        && optionalString(data, "customerPhone")
        && data.createdAt is timestamp;
    }

    match /services/{doc} {
      allow read: if true;
      allow create, update: if isAdmin() && validService(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{doc} {
      allow read: if true;
      allow create, update: if isAdmin() && validCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /blogs/{doc} {
      allow read: if true;
      allow create, update: if isAdmin() && validBlog(request.resource.data);
      allow delete: if isAdmin();
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && validHomepageContent(request.resource.data);
      allow delete: if isAdmin();
    }

    // UPDATED
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // phone-auth users can create only their own user profile
      // admins can create valid user/admin profiles
      allow create: if (
          isOwner(userId)
          && request.auth.token.firebase.sign_in_provider == "phone"
          && request.resource.data.role == "user"
          && request.resource.data.provider == "phone"
          && validUserProfile(request.resource.data, userId)
        ) || (
          isAdmin()
          && validUserProfile(request.resource.data, userId)
        );

      // phone-auth users can update only their own profile
      // role/createdAt stay locked for self-updates
      // provider can be corrected from null to "phone" for migration
      // admins can update any valid profile
      allow update: if (
          isOwner(userId)
          && request.auth.token.firebase.sign_in_provider == "phone"
          && resource.data.role == "user"
          && (resource.data.provider == "phone" || resource.data.provider == null)
          && request.resource.data.role == resource.data.role
          && request.resource.data.provider == "phone"
          && request.resource.data.createdAt == resource.data.createdAt
          && validUserProfile(request.resource.data, userId)
        ) || (
          isAdmin()
          && request.resource.data.createdAt == resource.data.createdAt
          && validUserProfile(request.resource.data, userId)
        );

      allow delete: if isAdmin();
    }

    match /users/{userId}/cart/{cartItemId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && validCartItem(request.resource.data, cartItemId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/addresses/{addressId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) || isAdmin()) && validAddress(request.resource.data);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /bookings/{bookingId} {
      allow create: if isSignedIn() && validBooking(request.resource.data);

      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.userId
          || isAdmin()
        );

      allow update, delete: if isAdmin();
    }
  }
}